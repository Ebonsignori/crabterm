{
  "$schema": "https://www.raycast.com/schemas/extension/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-jsx",
    "lib": ["ES2023"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src/**/*"]
}
